<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white_normal"
    android:paddingHorizontal="@dimen/page_padding_horizontal"
    android:paddingTop="@dimen/page_padding_top">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_2"
            android:text="Tambah Obat"
            android:textColor="@color/green_darker"
            style="@style/Headline1" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/spacing_6"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Obat"
                style="@style/Body2"
                android:textColor="@color/orange_darker" />

            <EditText
                android:id="@+id/etNamaObat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_0_5"
                android:hint="Paracetamol"
                style="@style/InputField" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_5"
                android:text="Waktu Konsumsi"
                android:textColor="@color/orange_darker"
                style="@style/Body2" />

            <Spinner
                android:id="@+id/spinnerWaktu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_0_5"
                android:background="@drawable/bg_input"
                android:entries="@array/waktu_konsumsi_array"
                android:padding="@dimen/spacing_4" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_5"
                android:text="Jam"
                android:textColor="@color/orange_darker"
                style="@style/Body2" />

            <TimePicker
                android:id="@+id/timePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_0_5"
                android:timePickerMode="spinner" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_5"
                android:text="Dosis"
                android:textColor="@color/orange_darker"
                style="@style/Body2" />

            <EditText
                android:id="@+id/etDosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_0_5"
                android:hint="2 Kapsul"
                style="@style/InputField" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_5"
                android:text="Catatan"
                android:textColor="@color/orange_darker"
                style="@style/Body2" />

            <EditText
                android:id="@+id/etCatatan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_0_5"
                android:gravity="top"
                android:hint="Input text"
                android:minHeight="80dp"
                style="@style/InputField" />

            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/spacing_8"
                android:layout_marginBottom="@dimen/spacing_8"
                android:text="Tambah Obat"
                style="@style/ButtonGreen" />

        </LinearLayout>
    </ScrollView>

    <!-- Floating Bottom Navigation Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white_card"
        app:cardUseCompatPadding="false">

        <LinearLayout
            android:id="@+id/bottomNavLayout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <!-- 1. Beranda -->
            <LinearLayout
                android:id="@+id/navBeranda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_inactive"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_0_5"
                    android:text="Beranda"
                    android:textColor="@color/white_darker"
                    style="@style/Body4" />
            </LinearLayout>

            <!-- 2. Tambah (Active) -->
            <LinearLayout
                android:id="@+id/navTambah"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_active"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_add_active" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_0_5"
                    android:text="Tambah"
                    android:textColor="@color/red_logo"
                    style="@style/Body4" />
            </LinearLayout>

            <!-- 3. Detail -->
            <LinearLayout
                android:id="@+id/navDetail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_inactive"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_detail" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_0_5"
                    android:text="Detail"
                    android:textColor="@color/white_darker"
                    style="@style/Body4" />
            </LinearLayout>

            <!-- 4. Tentang -->
            <LinearLayout
                android:id="@+id/navTentang"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_inactive"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_info" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_0_5"
                    android:text="Tentang"
                    android:textColor="@color/white_darker"
                    style="@style/Body4" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>