<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ========== NAVIGATION BAR STYLE ========== -->
    <style name="NavItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <!-- ========== BUTTON STYLES ========== -->
    <style name="ButtonGreen" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_green</item>
        <item name="android:textColor">@color/white_card</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/manrope_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="cornerRadius">100dp</item>
    </style>

    <!-- ========== INPUT FIELD STYLE ========== -->
    <style name="InputField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textColor">@color/text_form_dark</item>
        <item name="android:textColorHint">@color/white_dark</item>
    </style>

    <!-- Badge styles -->
    <style name="BadgeSudah">
        <item name="android:background">@drawable/bg_badge_sudah</item>
        <item name="android:textColor">@color/status_sudah_text</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/manrope_bold</item>
    </style>

    <style name="BadgeBelum">
        <item name="android:background">@drawable/bg_badge_belum</item>
        <item name="android:textColor">@color/status_belum_text</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/manrope_bold</item>
    </style>

</resources>